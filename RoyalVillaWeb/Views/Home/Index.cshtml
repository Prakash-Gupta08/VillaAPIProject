@using RoyalVilla.DTO
@using VillaWebAPI.DTO
@model IEnumerable<VillaDto>


<div id="heroCarousel" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label=""></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="slide 2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="slide 3"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Welcome to Luxury Villas</h1>
                    <p class="lead mb-4 fs-4">Discover your perfect gateway in paradise</p>
                    <a href="#villa-listings" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-arrow-down-circle"></i>Explore villas
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Premium Amenities</h1>
                    <p class="lead mb-4 fs-4">Experience luxury living at its finest</p>
                    <a href="#villa-listing" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-star-fill"></i>View Collection
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Book Your Dream</h1>
                    <p class="lead mb-4 fs-4">Unforgettable memories await you</p>
                    <a href="#villa-listing" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-calendar-check"></i>Check Availability
                    </a>
                </div>
            </div>
        </div>
    </div>s

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<div class="container mt-4" id="villa-listing">

    <!--Header Section-->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h2 class="display-4 fw-bold text-primary">
                    <i class="bi bi-house-door-fill"></i>Luxury Villa Collection
                </h2>
                <p class="lead text-muted">Browse our exclusive selection of premium properties</p>
                <div class="divider-custom">
                    <div class="divider-line"></div>
                    <div class="divider-icon"><i class="bi bi-gem"></i></div>
                    <div class="divider-line"></div>
                </div>
            </div>
        </div>
    </div>
    @if(TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role = "alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (Model == null || Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-info text-center" role="alert">
                    <i class="bi bi-info-circle-fill fs-1 d-block mb-3"></i>
                    <h4>No Villas Available</h4>
                    <p class="mb-0">There are currently no villas to display. Please check back later!</p>
                </div>
            </div>
        </div>
    }
    else

    {
        <!--Villa Cards Grid-->
        <div class="row row-cols-1 row-cols-2 row-cols-lg-3 g-4">
            foreach (var villa in Model)
            {
               
            <div class="col">
                <div class="card h-100 shadow-sm hover-shadow transition">
                    <!--Villa images-->
                    <div class="position-relative overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=1200" class="card-img-top villa-image" style="height: 250px; object-fit: cover;" />
                        <div class="card-img-top bg-gradient-primary d-flex align-items-center justify-content-center" style="height: 250px;">
                            <i class="bi bi-image text-white" style="font-size:4rem;"></i>
                        </div>
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge bg-success fs-5 px-3 py-2 rounded-pill shadow">
                                $$$/night
                            </span>
                        </div>
                    </div>

                    <!--Card Body-->
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary fw-bold mb-3">Name</h5>

                        <p class="card-text text-muted flex-grow-1">
                            Details
                        </p>

                        <!--Villa Details-->
                        <div class="mb-3">
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-people-fill text-primary me-2"></i>
                                        <small class="text-muted">XX Guest</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-square-fill text-primary me-2"></i>
                                        <small class="text-muted">XX sqft</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!--Action Buttons-->
                        <div class="d-grid gap-2">
                            <a href="https://taskcrm.mycrmdesk.com/agent/task-log/136" class="btn btn-primary btn-hover">
                                <i class="bi bi-envelope"></i>Contact Us
                            </a>
                        </div>
                    </div>
                </div>
            </div>
    }

    </div>
}
