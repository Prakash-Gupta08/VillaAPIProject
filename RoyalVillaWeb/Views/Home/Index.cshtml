@using RoyalVilla.DTO
@using VillaWebAPI.DTO
@model IEnumerable<VillaDto>


<div id="heroCarousel" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label=""></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="slide 2"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="slide 3"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Welcome to Luxury Villas</h1>
                    <p class="lead mb-4 fs-4">Discover your perfect gateway in paradise</p>
                    <a href="#villa-listings" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-arrow-down-circle"></i>Explore villas
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Premium Amenities</h1>
                    <p class="lead mb-4 fs-4">Experience luxury living at its finest</p>
                    <a href="#villa-listing" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-star-fill"></i>View Collection
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <div class="carousel-caption-custom">
                    <h1 class="display-3 fw-bold mb-4 animate-fade-in">Book Your Dream</h1>
                    <p class="lead mb-4 fs-4">Unforgettable memories await you</p>
                    <a href="#villa-listing" class="btn btn-light btn-lg px-5 smooth-scroll">
                        <i class="bi bi-calendar-check"></i>Check Availability
                    </a>
                </div>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<div class="container mt-4" id="villa-listing">

    <!--Header Section-->
    <div class="row mb-4">
        <div class="col-12">
            <div class="text-center">
                <h2 class="display-4 fw-bold text-primary">
                    <i class="bi bi-house-door-fill"></i>Luxury Villa Collection
                </h2>
                <p class="lead text-muted">Browse our exclusive selection of premium properties</p>
                <div class="divider-custom">
                    <div class="divider-line"></div>
                    <div class="divider-icon"><i class="bi bi-gem"></i></div>
                    <div class="divider-line"></div>
                </div>
            </div>
        </div>
    </div>
    @if(TempData["error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role = "alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["error"]
