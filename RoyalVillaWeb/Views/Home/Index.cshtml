@* </div> *@


<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">

    <div class="carousel-inner">

        <!-- Slide 1 -->
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1613977257363-707ba9348227"
                 class="d-block w-100 hero-img" />

            <div class="carousel-caption hero-content">
                <h1>Luxury Villas</h1>
                <p>Experience premium living with world-class amenities</p>
                <a href="/Villa" class="btn btn-primary">Explore Villas</a>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c"
                 class="d-block w-100 hero-img" />

            <div class="carousel-caption hero-content">
                <h1>Modern Interiors</h1>
                <p>Designed for comfort, elegance, and style</p>
                <a href="/Villa" class="btn btn-success">View Details</a>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c"
                 class="d-block w-100 hero-img" />

            <div class="carousel-caption hero-content">
                <h1>Private Pools & Gardens</h1>
                <p>Relax in your own peaceful paradise</p>
                <a href="/Contact" class="btn btn-warning">Book Now</a>
            </div>
        </div>

    </div>

    <!-- Controls -->
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

</div>

<div class="container mt-5">
    <h2 class="text-center mb-4">Featured Villas</h2>

    <div class="row">
        @foreach (var villa in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card villa-card h-100 shadow-sm">

                    <img src="@villa.ImageUrl" class="card-img-top villa-img" />

                    <div class="card-body">
                        <h5>@villa.Name</h5>
                        <p class="text-muted">@villa.Details</p>
                        <p class="fw-bold text-primary">₹@villa.Occupancy / night</p>
                    </div>

                    <div class="card-footer bg-white border-0">
                        <a href="#" class="btn btn-outline-primary w-100">
                            View Details
                        </a>
                    </div>

                </div>
            </div>
        }
    </div>
</div>

 <style>
    .hero-img {
        height: 90vh;
        object-fit: cover;
        filter: brightness(70%);
    }

    .hero-content {
        top: 50%;
        transform: translateY(-50%);
        bottom: auto;
    }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: bold;
        }

        .hero-content p {
            font-size: 1.3rem;
            margin-bottom: 20px;
        }

 </style>